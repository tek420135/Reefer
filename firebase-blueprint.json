{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "xp": { "type": "number", "description": "The user's experience points." },
        "seeds": { "type": "number", "description": "The user's digital seeds count." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase record for a product.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's ID who placed the order." },
        "productId": { "type": "string", "description": "The ID of the product purchased." },
        "productName": { "type": "string", "description": "The name of the product." },
        "price": { "type": "number", "description": "The price paid." },
        "status": { "type": "string", "description": "The order status (pending, completed, etc.)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed." }
      },
      "required": ["uid", "productId", "productName", "price", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": "Order",
      "description": "User's order history."
    }
  }
}
